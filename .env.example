# PostgreSQL
POSTGRES_USER=cti
POSTGRES_PASSWORD=changeme
POSTGRES_DB=cti

# Security
FEED_ENCRYPTION_KEY=generate-a-fernet-key

# Authentication
# Initial admin user created on first boot if no users exist
# Set a strong password — leave empty to skip admin user seeding
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
# Required in production. Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# In development mode only, an empty value auto-generates a random secret (sessions lost on restart)
JWT_SECRET_KEY=
# Set to true when running behind a reverse proxy (e.g., nginx in docker-compose)
TRUST_PROXY_HEADERS=true

# Logging
LOG_LEVEL=INFO
ENVIRONMENT=production

# Optional feed API keys (leave empty to skip)
ABUSEIPDB_API_KEY=
URLSCAN_API_KEY=
THREATFOX_API_KEY=
PHISHTANK_API_KEY=
