# PostgreSQL
POSTGRES_USER=cti
POSTGRES_PASSWORD=changeme
POSTGRES_DB=cti

# Security
FEED_ENCRYPTION_KEY=generate-a-fernet-key

# Authentication
# Initial admin user created on first boot if no users exist
# Leave ADMIN_PASSWORD empty to skip admin user seeding
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme
# Optional: set a stable secret to persist sessions across container restarts
# If empty, a random secret is generated on each startup (all sessions lost on restart)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=

# Logging
LOG_LEVEL=INFO
ENVIRONMENT=production

# Optional feed API keys (leave empty to skip)
ABUSEIPDB_API_KEY=
URLSCAN_API_KEY=
THREATFOX_API_KEY=
PHISHTANK_API_KEY=
