# CTI Platform Configuration
# Copy to .env and fill in values

# Application
ENVIRONMENT=development
SECRET_KEY=change-me-to-a-random-secret-key
ADMIN_PASSWORD=admin
LOG_LEVEL=INFO

# PostgreSQL
POSTGRES_USER=cti
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=cti

# Redis
REDIS_URL=redis://localhost:6379/0

# Elasticsearch
ELASTICSEARCH_URL=http://localhost:9200

# JWT
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_ALGORITHM=HS256

# CORS
CORS_ORIGINS=["http://localhost:5173","http://localhost:8080"]

# Feed defaults
FEED_DEFAULT_TIMEOUT=30
FEED_MAX_RETRIES=3

# Encryption key for feed credentials (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
FEED_ENCRYPTION_KEY=change-me-generate-a-fernet-key

# Feed API keys (optional - feeds requiring keys are created but disabled without them)
ABUSEIPDB_API_KEY=
